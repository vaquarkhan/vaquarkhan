# Card Linked Benefits Platform Environment Configuration
# Copy this file to .env and update the values for your environment

# Database Configuration
DB_HOST=ezyclo-mysql
DB_PORT=3306
DB_NAME=card_benefits_platform
DB_USERNAME=benefits_user
DB_PASSWORD=benefits_password
DB_ROOT_PASSWORD=rootpassword

# Redis Configuration
REDIS_HOST=ezyclo-redis
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Configuration
JWT_SECRET=your-super-secure-jwt-secret-key-change-in-production-256-bits-long
JWT_EXPIRATION=86400000

# Encryption Configuration
ENCRYPTION_KEY=your-256-bit-encryption-key-change-in-production
PAN_TOKENIZATION_KEY=your-pan-tokenization-key-change-in-production

# External API Configuration
MASTERCARD_API_ENDPOINT=https://api.mastercard.com/benefits
MASTERCARD_CLIENT_ID=your-mastercard-client-id
MASTERCARD_CLIENT_SECRET=your-mastercard-client-secret
MASTERCARD_CERTIFICATE_PATH=/app/certs/mastercard.p12
MASTERCARD_CERTIFICATE_PASSWORD=your-certificate-password

VISA_API_ENDPOINT=https://api.visa.com/benefits
VISA_CLIENT_ID=your-visa-client-id
VISA_CLIENT_SECRET=your-visa-client-secret

# Notification Configuration
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=your-email@domain.com
EMAIL_PASSWORD=your-email-password

SMS_PROVIDER=twilio
SMS_ACCOUNT_SID=your-twilio-account-sid
SMS_AUTH_TOKEN=your-twilio-auth-token
SMS_FROM_NUMBER=+1234567890

# Security Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:8080,https://yourdomain.com
API_RATE_LIMIT_REQUESTS=1000
API_RATE_LIMIT_WINDOW=3600

# Monitoring Configuration
PROMETHEUS_ENABLED=true
GRAFANA_ADMIN_PASSWORD=admin123

# SSL Configuration (Production)
SSL_ENABLED=false
SSL_KEYSTORE_PATH=/app/ssl/keystore.p12
SSL_KEYSTORE_PASSWORD=your-keystore-password
SSL_KEY_ALIAS=benefits-platform

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=your-backup-bucket
BACKUP_S3_ACCESS_KEY=your-s3-access-key
BACKUP_S3_SECRET_KEY=your-s3-secret-key

# Development Configuration
SPRING_PROFILES_ACTIVE=dev
NODE_ENV=development
DEBUG_ENABLED=true